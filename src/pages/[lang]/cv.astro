---
import Layout from '@layouts/Layout.astro';
import PageTitle from '@components/layout/PageTitle.astro';
import { getLangFromUrl, useTranslations } from '@i18n/utils';
import { getLangStaticPaths } from '@utils/useRoutes';
import { getSkillsData } from '@content/skills/skills.data';

export async function getStaticPaths() {
  return getLangStaticPaths();
}

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const pageTitle = `${t('seo.baseTitleTag')} | ${t('cv.titleTag')}`;
const skillsData = getSkillsData(currentLang);
---

<Layout title={pageTitle}>
  <PageTitle title={ t('cv.pageTitle') } subtitle={ t('cv.subtitle') } />
  <div class="p-8 pt-0">
    <div class="flex flex-wrap -mx-8">
      <div class="w-full lg:w-2/3 px-8">
        <div class="pb-8 border-b-2 border-solid border-light dark:border-dark transition-colors duration-200 ease-in-out">
          <div class="title-area mb-4">
            <h2 class="text-2xl font-black small-caps dark:text-light transition-colors duration-200 ease-in-out">
              { t('cv.skills.title') }
            </h2>
          </div>
          <div class="skills-wrapper grid gap-6">
            {Object.values(skillsData).map((category) => (
              <div class="skill-item">
                <h3 class="mb-2 text-lg font-black small-caps dark:text-light transition-colors duration-200 ease-in-out">
                  {category.title}
                </h3>
                <div class="skill-description dark:text-light transition-colors duration-200 ease-in-out">
                  <ul class="list-disc list-inside">
                    {category.skillsList.map((skill) => (
                      <li set:html={skill} />
                    ))}
                  </ul>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="py-8 border-b-2 border-solid border-light dark:border-dark transition-colors duration-200 ease-in-out">
          <div class="title-area mb-4">
            <h2 class="text-2xl font-black small-caps dark:text-light transition-colors duration-200 ease-in-out">
              { t('cv.experiences.title') }
            </h2>
          </div>
          <div class="experiences-wrapper grid gap-6">

          </div>
        </div>
      </div>
      <div class="w-full lg:w-1/3 lg:pl-8 pt-8 lg:pt-0 lg:fixed lg:right-0 lg:top-1/2 lg:-translate-y-1/2">
        Element flottant
      </div>
    </div>
  </div>
</Layout>
