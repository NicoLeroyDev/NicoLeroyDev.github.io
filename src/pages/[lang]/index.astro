---
import { getCollection } from 'astro:content';
import Home from '@components/Home.astro';
import Layout from '@layouts/Layout.astro';

export async function getStaticPaths() {
	const languages = ['fr', 'en'];

	return languages.map(lang => ({
		params: { lang },
		props: { lang },
	}));
}
---

<Layout>
	<Home />
</Layout>
