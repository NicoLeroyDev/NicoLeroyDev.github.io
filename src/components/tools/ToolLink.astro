---
import { Image } from 'astro:assets';
import { getToolImage } from '@content/tools/imageMap';

const { tool, target, classNames } = Astro.props;
---

<a title={tool?.data?.label}
   href={tool?.data?.url}
   target={target}
   rel="noopener noreferrer"
   class={classNames}
>
    <Image src={getToolImage(tool.id)} alt={tool.data.label} class="h-full w-auto" width={40} height={40} />
</a>