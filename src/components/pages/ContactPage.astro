---
import Layout from '@layouts/Layout.astro';
import PageTitle from '@components/layout/PageTitle.astro';
import { useTranslations } from '@i18n/utils';
import { generateCaptcha } from '@utils/captcha';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const pageTitle = `${t('seo.baseTitleTag')} | ${t('contact.titleTag')}`;

const captcha = generateCaptcha();
const captchaPlaceholder = t('contact.form.captcha.placeholder')
    .replace('{num1}', captcha.num1.toString())
    .replace('{num2}', captcha.num2.toString());
---

<Layout title={pageTitle}>
  <PageTitle title={ t('contact.pageTitle') } subtitle={ t('contact.subtitle') } />

  <div class="p-8 pt-0">
    <form class="js-contact-form" method="POST">
      <div class="grid sm:grid-cols-2 gap-x-8 gap-y-4">
        <div class="flex flex-col gap-y-1">
          <label for="firstname" class="text-xs dark:text-light transition-colors duration-200 ease-in-out">{ t('contact.form.firstname') }</label>
          <input id="firstname" name="firstname" type="text" required class="border border-solid border-dark rounded px-2 h-8" />
        </div>
        <div class="flex flex-col gap-y-1">
          <label for="lastname" class="text-xs dark:text-light transition-colors duration-200 ease-in-out">{ t('contact.form.lastname') }</label>
          <input id="lastname" name="lastname" type="text" required class="border border-solid border-dark rounded px-2 h-8" />
        </div>
        <div class="flex flex-col gap-y-1">
          <label for="email" class="text-xs dark:text-light transition-colors duration-200 ease-in-out">{ t('contact.form.email') }</label>
          <input id="email" name="email" type="email" required class="border border-solid border-dark rounded px-2 h-8" />
        </div>
        <div class="flex flex-col gap-y-1">
          <label for="subject" class="text-xs dark:text-light transition-colors duration-200 ease-in-out">{ t('contact.form.subject') }</label>
          <input id="subject" name="subject" type="text" required class="border border-solid border-dark rounded px-2 h-8" />
        </div>
        <div class="flex flex-col gap-y-1">
          <label for="captcha" class="text-xs dark:text-light transition-colors duration-200 ease-in-out">{ t('contact.form.captcha.label') }</label>
          <input id="captcha" name="captcha" type="text" inputmode="numeric" required placeholder={captchaPlaceholder} class="border border-solid border-dark rounded px-2 h-8" />
          <input type="hidden" name="captchaToken" value={captcha.token} />
        </div>
      </div>

      <div class="oh" aria-hidden="true">
        <label for="website">Website</label>
        <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
      </div>

      <div class="grid gap-x-8 my-4">
        <div class="flex flex-col gap-y-1">
          <label for="message" class="text-xs dark:text-light transition-colors duration-200 ease-in-out">{ t('contact.form.message') }</label>
          <textarea id="message" name="message" rows="6" required class="border border-solid border-dark rounded px-2 py-1 h-[150px]"></textarea>
        </div>
      </div>
      <div class="button-link relative inline-block">
        <span class="border-glow absolute top-[-1px] left-[-1px]"></span>
        <button type="submit"
                class="inline-flex relative px-4 py-2 border border-solid border-dark bg-dark text-light transition-colors duration-200 ease-in-out
                dark:border-light dark:bg-light dark:text-dark
                hover:bg-white hover:text-dark
                dark:hover:bg-dark dark:hover:text-light"
        >
          { t('contact.form.submit') }
        </button>
      </div>
    </form>
  </div>
</Layout>

<script>
  const form = document.querySelector('.js-contact-form') as HTMLFormElement;
  
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      
      const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (submitButton) submitButton.disabled = true;

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(data)
        });

        if (response.ok) {
          alert('Message envoyé avec succès !');
          form.reset();
        } else {
          const result = await response.json();
          alert(result.error || 'Une erreur est survenue lors de l\'envoi du message.');
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Une erreur est survenue lors de l\'envoi du message.');
      } finally {
        if (submitButton) submitButton.disabled = false;
      }
    });
  }
</script>

<style>
  @reference "@styles/tailwind-config.css";

  .button-link {

    &:hover,
    &:focus,
    &:active {

      .border-glow {
        @apply opacity-100;
      }
    }

    .border-glow {
      width: calc(100% + 2px);
      height: calc(100% + 2px);
      animation: glowing-button 60s linear infinite;
      filter: blur(2px);
      background-size: 300% auto;
      background-image: linear-gradient(
          90deg,
          var(--color-blue),
          var(--color-yellow),
          var(--color-pink),
          var(--color-blue),
          var(--color-yellow),
          var(--color-pink),
          var(--color-blue)
      );
      @apply opacity-0 transition-opacity duration-200 ease-in-out;
    }
  }

  .oh {
    position: absolute;
    left: -5000px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  @keyframes glowing-button {
    0% {
      background-position: 0 0;
    }
    50% {
      background-position: 300% 0;
    }
    100% {
      background-position: 0 0;
    }
  }
</style>
