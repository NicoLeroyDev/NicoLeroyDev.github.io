---
import { getLangFromUrl, useTranslations } from '@i18n/utils';
import { getCollection } from 'astro:content';
import { getEducationsData } from '@content/education/education.data';
import { getEducationImages } from '@content/education/imageMap';
import { Image } from 'astro:assets';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

const educations = await getCollection('education');
const educationsData = getEducationsData(currentLang);

const sortedEducations = educations.sort((a, b) => b.data.sort - a.data.sort);
---
<div class="py-8">
  <div class="title-area mb-4">
    <h2 class="text-2xl font-black small-caps dark:text-light transition-colors duration-200 ease-in-out">
      { t('cv.education.title') }
    </h2>
  </div>
  <div class="diplomas-wrapper grid gap-6">
    {sortedEducations.map((education) => {
      const data = (educationsData as any)[education.slug];
      const { logo, badge } = getEducationImages(education.slug);

      if (!data) return null;

      return (
        <div class="diploma-item">
          <div class="flex">
            {logo && (
              <div class="logo w-20 h-[48px] mr-4 bg-white border border-solid border-dark flex justify-center items-center p-2">
                <Image src={logo} alt={data.location} class="max-w-full h-auto max-h-full" />
              </div>
            )}
            <div class="text">
              <h3 class="text-lg font-black small-caps dark:text-light transition-colors duration-200 ease-in-out">
                {data.label}
              </h3>
              <div class="flex items-center text-sm italic dark:text-light transition-colors duration-200 ease-in-out">
                <p>
                  {`${t('date.from')} `}
                  <strong>{data.startDateString}</strong>
                  {`${t('date.to')} `}
                  <strong>{data.endDateString}</strong>
                </p>
              </div>
            </div>
          </div>
          <div class="diploma-description pl-24 mt-4 dark:text-light transition-colors duration-200 ease-in-out">
            <div>
              <p>{data.description}</p>
              {data.complementary && (
                  <p>
                    <strong>{data.complementary}</strong>
                  </p>
              )}
              <p>{data.location}</p>
            </div>
            {badge && (
                <div class="badge">
                  <div class="mt-2 w-20 h-[48px]">
                    <Image src={badge} loading="lazy" alt="Badge" class="max-w-full w-auto h-auto max-h-full" />
                  </div>
                </div>
            )}
          </div>
        </div>
      );
    })}
  </div>
</div>
