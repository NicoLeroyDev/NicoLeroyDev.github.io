---
import { Image } from 'astro:assets';
import cvMiniature from '@assets/cv.jpg';
import cvFile from '@assets/cv-nicolas-leroy.pdf?url';
import SvgDefs from '@components/icons/SvgDefs.vue';
import ButtonLink from '@components/ui/ButtonLink.astro';
import { getLangFromUrl, useTranslatedPath, useTranslations } from '@i18n/utils';
import {getProjectUrl} from "@utils/useRoutes.ts";
import fs from 'node:fs';
import path from 'node:path';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const translatePath = useTranslatedPath(currentLang);

const cvPath = path.resolve('src/assets/cv-nicolas-leroy.pdf');
const stats = fs.statSync(cvPath);
const fileSizeInBytes = stats.size;
const fileSizeInMegabytes = (fileSizeInBytes / (1024 * 1024)).toFixed(2);
---
<div class="w-full lg:w-1/3 lg:pl-8 pt-8 lg:pt-0 lg:fixed lg:right-0 lg:top-1/2 lg:-translate-y-1/2">
  <div class="p-8 h-full bg-dark text-light dark:bg-light dark:text-dark transition-colors duration-200 ease-in-out">
    <div class="dl-cv-wrapper flex justify-center lg:justify-normal lg:flex-col items-center gap-4 pb-8 border-b border-solid border-light dark:border-dark transition-colors duration-200 ease-in-out">
      <div class="img w-24 shadow-lg shrink-0">
        <Image src={ cvMiniature } class="w-full h-auto" alt={ t('cv.floatingElem.miniature.alt') } />
      </div>
      <div class="text text-light dark:text-dark transition-colors duration-200 ease-in-out">
        <p class="font-semibold lg:text-center">
          { t('cv.floatingElem.miniature.title') }
        </p>
        <div class="cta mt-4 flex lg:justify-center">
          <div class="button-link relative inline-block">
            <span class="border-glow absolute top-[-1px] left-[-1px]"></span>
            <a class="w-full relative flex justify-center px-4 py-2 text-center border border-solid transition-colors duration-200 ease-in-out border-light bg-light text-dark dark:border-dark dark:bg-dark dark:text-light hover:bg-dark dark:hover:bg-light hover:text-light dark:hover:text-dark"
               href={cvFile}
               target="_blank"
            >
              <SvgDefs width="20"
                       height="20"
                       class="mr-2 mx-auto transition-colors duration-200 ease-out"
                       id="download"
              />
              <span class="flex items-center">
                { t('cv.floatingElem.miniature.cta') }
                <span class="hidden xl:inline text-xs font-bold pl-2">
                  ({fileSizeInMegabytes} Mo)
                </span>
              </span>
            </a>
          </div>
        </div>
      </div>
    </div>
    <div class="contact-wrapper pt-8">
      <p class="text-center font-semibold">
        { t('cv.floatingElem.contact.title') }
      </p>
      <div class="cta flex justify-center mt-4">
        <ButtonLink
            type="light"
            href={ translatePath('/contact') }
            label={ t('cv.floatingElem.contact.cta') }
        />
      </div>
    </div>
  </div>
</div>

<style>
  @reference "@styles/tailwind-config.css";

  .button-link {

    &:hover,
    &:focus,
    &:active {

      .border-glow {
        @apply opacity-100;
      }
    }

    .border-glow {
      width: calc(100% + 2px);
      height: calc(100% + 2px);
      animation: glowing-button 60s linear infinite;
      filter: blur(2px);
      background-size: 300% auto;
      background-image: linear-gradient(
          90deg,
          var(--color-blue),
          var(--color-yellow),
          var(--color-pink),
          var(--color-blue),
          var(--color-yellow),
          var(--color-pink),
          var(--color-blue)
      );
      @apply opacity-0 transition-opacity duration-200 ease-in-out;
    }
  }

  @keyframes glowing-button {
    0% {
      background-position: 0 0;
    }
    50% {
      background-position: 300% 0;
    }
    100% {
      background-position: 0 0;
    }
  }
</style>